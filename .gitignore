# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ─── Model files (ukuran besar, tidak perlu di-upload ke GitHub) ───
/database/*.keras
/database/*.h5
/database/*.pt
/database/*.pth
/database/*.pkl
/database/*.db
/database/*.sqlite

# ─── Python cache ──────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
*.spec

# ─── AI / Agent config (hanya untuk lokal, bukan bagian kode) ──────
/.claude/
CLAUDE.md
AGENTS.md

# ─── Editor config (spesifik lokal) ────────────────────────────────
/.vscode/

# ─── Folder public kosong (tidak ada aset yang dipakai) ────────────
/public/
